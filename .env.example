# Copy to .env and fill in real values. Never commit .env.
# Local dev (bun dev) talks to the compose DB on localhost;
# inside docker compose the app container gets db:5432 instead.
DATABASE_URL=postgres://app:app@localhost:5432/stellwerk
ANTHROPIC_API_KEY=

# Single-user login password for the app UI.
APP_PASSWORD=

# Host port for the Postgres container (default 5432).
# Override if 5432 is already taken on your machine — keep it
# in sync with the port in DATABASE_URL.
#DB_PORT=5433
